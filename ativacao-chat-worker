export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const method = request.method;

    try {
      // --- ROTA 1: PÁGINA DE CAPTURA (FRONTEND) ---
      if (url.pathname === "/" && method === "GET") {
        const produtoId = url.searchParams.get("p");
        if (!produtoId) {
          return new Response("ID do produto não informado", { status: 400 });
        }

        const produto = await env.DB.prepare(`
          SELECT id, nome_produto, preco
          FROM produtos
          WHERE id = ?
        `).bind(produtoId).first();

        if (!produto) {
          return new Response("Produto não encontrado", { status: 404 });
        }

        return new Response(getHTML(produto), {
          headers: { "Content-Type": "text/html;charset=UTF-8" }
        });
      }

      // --- ROTA 2: CRIAÇÃO DO PAGAMENTO (BACKEND) ---
     if (url.pathname === "/criar-pagamento" && method === "POST") {
      try {
        const formData = await request.formData();
        const produtoId = formData.get("produto_id")?.toString();
        const emailCru = formData.get("email")?.toString() || "";
        const dominio = formData.get("dominio")?.toString() || "";

        // Validações
        if (!produtoId || !dominio || !emailCru) {
          return new Response(JSON.stringify({ error: "Campos obrigatórios não preenchidos" }), {
            status: 400,
            headers: { "Content-Type": "application/json" }
          });
        }

        const emailLimpo = emailCru.trim().toLowerCase().replace(/[<>'"();\\]/g, "");
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailLimpo)) {
          return new Response(JSON.stringify({ error: "E-mail inválido" }), {
            status: 400,
            headers: { "Content-Type": "application/json" }
          });
        }

        // Busca produto
        const produto = await env.DB.prepare(`
          SELECT id, nome_produto, preco
          FROM produtos
          WHERE id = ?
        `).bind(parseInt(produtoId)).first();

        if (!produto) {
          return new Response(JSON.stringify({ error: "Produto não encontrado" }), {
            status: 404,
            headers: { "Content-Type": "application/json" }
          });
        }

        // Verifica se o domínio já está ativo
        const dominioAtivo = await env.DB.prepare(`
          SELECT id FROM dominios_autorizados
          WHERE dominio = ? AND ativo = 1
        `).bind(dominio).first();

        if (dominioAtivo) {
          return new Response(JSON.stringify({
            error: "Domínio já ativo",
            message: "Seu domínio já está ativo. Verifique seu e-mail para instruções ou entre em contato com o suporte."
          }), {
            status: 400,
            headers: { "Content-Type": "application/json" }
          });
        }

        // Verifica se já existe uma transação pendente para este e-mail/domínio
        const transacaoExistente = await env.DB.prepare(`
          SELECT ref FROM transacoes_pendentes
          WHERE email = ? AND status = 'pending'
        `).bind(emailLimpo).first();

        if (transacaoExistente) {
          // Se já houver uma transação pendente, redireciona para o pagamento existente
          const dataMP = await fetch(`https://api.mercadopago.com/checkout/preferences/search?external_reference=${transacaoExistente.ref}`, {
            headers: { "Authorization": `Bearer ${env.MP_ACCESS_TOKEN}` }
          }).then(res => res.json());

          if (dataMP.results && dataMP.results.length > 0 && dataMP.results[0].init_point) {
            return Response.redirect(dataMP.results[0].init_point, 302);
          }
        }

        // Verifica/cadastra cliente
        let cliente = await env.DB.prepare(`
          SELECT id, tenant_id FROM clientes
          WHERE email = ?
        `).bind(emailLimpo).first();

        let tenantId;
        if (!cliente) {
          tenantId = `tenant-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
          await env.DB.prepare(`
            INSERT INTO clientes
            (tenant_id, nome_empresa, email, criado_em, ativo)
            VALUES (?, ?, ?, datetime('now'), 1)
          `).bind(tenantId, dominio, emailLimpo).run();
        } else {
          tenantId = cliente.tenant_id;
        }

        // Verifica se o domínio já está cadastrado (mas não ativo)
        const dominioExistente = await env.DB.prepare(`
          SELECT id FROM dominios_autorizados
          WHERE dominio = ? AND email_cliente = ? AND ativo = 0
        `).bind(dominio, emailLimpo).first();

        if (!dominioExistente) {
          // Registra domínio (somente se não existir ou não estiver ativo)
          await env.DB.prepare(`
            INSERT INTO dominios_autorizados
            (dominio, ativo, data, tenant_id, email_cliente)
            VALUES (?, 0, datetime('now'), ?, ?)
          `).bind(dominio, tenantId, emailLimpo).run();
        }

        // Registra transação pendente
        const refUnica = crypto.randomUUID();
        await env.DB.prepare(`
          INSERT INTO transacoes_pendentes
          (ref, email, status, produto_id, data_criacao)
          VALUES (?, ?, 'pending', ?, datetime('now'))
        `).bind(refUnica, emailLimpo, produto.id).run();

        // Cria pagamento no Mercado Pago
        const mpRes = await fetch("https://api.mercadopago.com/checkout/preferences", {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${env.MP_ACCESS_TOKEN}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            items: [{
              title: produto.nome_produto,
              unit_price: parseFloat(produto.preco),
              quantity: 1,
              currency_id: "BRL"
            }],
            external_reference: refUnica,
            back_urls: {
              success: "https://wacshield.com/sucesso",
              failure: "https://wacshield.com/falha",
              pending: "https://wacshield.com/pendente"
            },
            auto_return: "approved",
            notification_url: "https://licenca.wacshield.com/webhook"
          })
        });

        if (!mpRes.ok) {
          const errorData = await mpRes.json();
          console.error("Erro Mercado Pago:", errorData);
          return new Response(JSON.stringify({
            error: "Erro no pagamento",
            details: errorData
          }), {
            status: mpRes.status,
            headers: { "Content-Type": "application/json" }
          });
        }

        const dataMP = await mpRes.json();
        if (!dataMP.init_point) {
          return new Response(JSON.stringify({
            error: "Link de pagamento não gerado"
          }), {
            status: 500,
            headers: { "Content-Type": "application/json" }
          });
        }

        return Response.redirect(dataMP.init_point, 302);
      } catch (err) {
        console.error("Erro em /criar-pagamento:", err);
        return new Response(JSON.stringify({
          error: "Erro interno",
          details: err.message
        }), {
          status: 500,
          headers: { "Content-Type": "application/json" }
        });
      }
    }

      // --- ROTA 3: WEBHOOK (APROVAÇÃO/CANCELAMENTO) ---
if (url.pathname === "/webhook") {
  const paymentId = url.searchParams.get("data.id");
  if (!paymentId) return new Response("OK", { status: 200 });

  ctx.waitUntil((async () => {
    try {
      const paymentData = await fetch(`https://api.mercadopago.com/v1/payments/${paymentId}`, {
        headers: { "Authorization": `Bearer ${env.MP_ACCESS_TOKEN}` }
      }).then(res => res.json());

      if (!paymentData.id || !["approved", "cancelled"].includes(paymentData.status)) return;

      const refRecebida = paymentData.external_reference;
      const status = paymentData.status;

      // Atualiza transação
      await env.DB.prepare(`
        UPDATE transacoes_pendentes
        SET status = ?
        WHERE ref = ? AND status = 'pending'
      `).bind(status, refRecebida).run();

      // Busca dados da transação
      const transacao = await env.DB.prepare(`
        SELECT email, produto_id
        FROM transacoes_pendentes
        WHERE ref = ?
      `).bind(refRecebida).first();

      if (!transacao) return;

      // Busca domínio associado ao e-mail
      const dominioInfo = await env.DB.prepare(`
        SELECT dominio, tenant_id FROM dominios_autorizados
        WHERE email_cliente = ? AND ativo = 0
      `).bind(transacao.email).first();

      if (!dominioInfo) return;

      async function gerarHashSHA256(senha) {
        const encoder = new TextEncoder();
        const data = encoder.encode(senha);
        const hashBuffer = await crypto.subtle.digest('SHA-256', data);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      }

     // --- APROVAÇÃO ---
        if (status === "approved") {
          const senhaPainel = Math.random().toString(36).slice(-8);
          const codigoVenda = `Venda-${transacao.produto_id}-${Date.now()}`;
          const senhaHash = await gerarHashSHA256(senhaPainel); // Gera hash da senha

          // Atualiza domínio (ativo=1, codigo_venda, senha_painel)
          await env.DB.prepare(`
            UPDATE dominios_autorizados
            SET ativo = 1, codigo_venda = ?, senha_painel = ?
            WHERE email_cliente = ? AND dominio = ?
          `).bind(codigoVenda, senhaHash, transacao.email, dominioInfo.dominio).run(); // Salva hash no banco

          // --- CRIA/ATUALIZA LOGIN NA TABELA wac_login ---
          // Verifica se o login já existe
          const loginExistente = await env.DB.prepare(`
            SELECT id FROM wac_login
            WHERE usuario = ? AND tenant_id = ?
          `).bind(transacao.email, dominioInfo.tenant_id).first();

          if (loginExistente) {
            // Atualiza a senha do login existente (com hash)
            await env.DB.prepare(`
              UPDATE wac_login
              SET senha = ?
              WHERE usuario = ? AND tenant_id = ?
            `).bind(senhaHash, transacao.email, dominioInfo.tenant_id).run();
          } else {
            // Cria um novo login (com hash)
            await env.DB.prepare(`
              INSERT INTO wac_login
              (usuario, senha, tenant_id, role, nome)
              VALUES (?, ?, ?, 'user', ?)
            `).bind(
              transacao.email,
              senhaHash, // Salva hash no banco
              dominioInfo.tenant_id,
              dominioInfo.dominio
            ).run();
          }

          // Envia e-mail com credenciais (senha em texto claro)
          await enviarEmailBrevo(
            transacao.email,
            `Seu domínio foi ativado!`,
            `<div style="font-family: Arial; font-size: 16px; sans-serif; max-width: 600px; margin: 0 auto; background-color: #f9f9f9; padding: 20px; border-radius: 8px;">
              <div style="background-color: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);">
                <h1 style="text-align: center; color: #3b82f6;">Seu domínio foi ativado!</h1>
                <p>Olá,</p>
                <p>Seu acesso foi liberado com sucesso. Abaixo estão as informações para começar:</p>
                <ul>
                  <li><strong>Acessar Painel:</strong> <a href="https://painel.wacshield.com/painel" target="_blank">Acessar Painel</a></li>
                  <li><strong>Usuário:</strong> ${transacao.email}</li>
                  <li><strong>Senha:</strong> ${senhaPainel}</li>
                  <li><strong>Código de venda:</strong> ${codigoVenda}</li>
                </ul>
                <p>Se precisar de ajuda, responda este e-mail.</p>
              </div>
              <div style="text-align: center; margin-top: 20px; font-size: 12px; color: #777;">
                <p>© WAC Shield Solutions</p>
                <p>Duque de caxias 796, 09999-999, Jandira</p>
              </div>
            </div>`,
            env
          );
            }
              // --- CANCELAMENTO ---
            else if (status === "cancelled") {
              await env.DB.prepare(`
                UPDATE dominios_autorizados
                SET ativo = 0, senha_painel = NULL
                WHERE email_cliente = ? AND dominio = ?
              `).bind(transacao.email, dominioInfo.dominio).run();

              await enviarEmailBrevo(
                transacao.email,
                `Pagamento Cancelado para ${dominioInfo.dominio}`,
                `O pagamento foi cancelado. Seu domínio foi desativado.`,
                env
              );
            }
          } catch (err) {
            console.error("Erro no webhook:", err);
          }
        })());
        return new Response("OK", { status: 200 });
      }

      return new Response("Rota não encontrada", { status: 404 });
    } catch (err) {
      console.error("Erro global:", err);
      return new Response("Erro interno", { status: 500 });
    }
  }
};

    // --- FUNÇÃO AUXILIAR: ENVIO BREVO (COM LOGS) ---
    async function enviarEmailBrevo(email, assunto, mensagem, env) {
      if (!env.BREVO_API_KEY || !env.EMAIL_REMETENTE) {
        console.error("Brevo não configurada: Chave ou e-mail remetente faltando.");
        return { error: "Brevo não configurada" };
      }

      try {
        const response = await fetch("https://api.brevo.com/v3/smtp/email", {
          method: "POST",
          headers: {
            "api-key": env.BREVO_API_KEY,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            sender: { name: "WAC Shield", email: env.EMAIL_REMETENTE },
            to: [{ email }],
            subject: assunto,
            htmlContent: mensagem // Envia o HTML puro, sem `<pre>`
          })
        });

        const responseData = await response.json();
        if (!response.ok) {
          console.error("Erro ao enviar e-mail:", responseData);
          return { error: "Falha ao enviar e-mail", details: responseData };
        }
        return responseData;
      } catch (err) {
        console.error("Erro na requisição Brevo:", err);
        return { error: "Erro na requisição", details: err.message };
      }
    }

// --- FUNÇÃO AUXILIAR: HTML (SEM ALTERAÇÕES) ---
function getHTML(produto) {
  return `
  <!DOCTYPE html>
  <html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ativação WAC Shield</title>
    <style>
      body { background: #f8fafc; color: #1e293b; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
      .card { background: white; padding: 2rem; border-radius: 1rem; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 1px solid #e2e8f0; }
      h2 { color: #3b82f6; margin-top: 0; }
      input { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #cbd5e0; margin: 1rem 0; box-sizing: border-box; }
      button { width: 100%; padding: 12px; border: none; border-radius: 8px; background: #3b82f6; color: white; font-weight: bold; cursor: pointer; }
      button:hover { background: #2563eb; }
    </style>
  </head>
  <body>
    <div class="card">
      <h2>Ativação de Domínio</h2>
      <p>Produto: <strong>${produto.nome_produto}</strong></p>
      <p>Valor: <strong>R$ ${produto.preco.toFixed(2)}</strong></p>
      <form action="/criar-pagamento" method="POST">
        <input type="hidden" name="produto_id" value="${produto.id}">
        <input type="email" name="email" placeholder="Seu e-mail" required>
        <input type="text" name="dominio" placeholder="seudominio.com.br" required>
        <button type="submit">Continuar para Pagamento</button>
      </form>
    </div>
  </body>
  </html>`;
}
